# Copy this file to .env and fill in your values
# .env is git-ignored — never commit actual credentials

# GitHub credentials for this project
GITHUB_USERNAME=your_github_username
GITHUB_TOKEN=your_personal_access_token

# Dataset source (public — no token needed)
DATASET_URL=https://raw.githubusercontent.com/HarshvardhanSingh-13/Datasets/main/Titanic_Dataset/Titanic-Dataset.csv
DATASET_REPO=https://github.com/HarshvardhanSingh-13/Datasets

# Project identity
PROJECT_NAME=Titanic EDA - YData Profiling
PROJECT_AUTHOR=Prajwal Nerkar
